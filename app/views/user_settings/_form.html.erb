<%
  form_options = { model: user_setting, class: "mt-6 space-y-4" }
  form_options[:url] = form_url if local_assigns[:form_url].present?
%>

<%= form_with(**form_options) do |f| %>
  <%= render "shared/form_errors", record: user_setting %>

  <div>
    <%= f.label :target_daily_cigarette_count, "1日の目標本数", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
    <%= f.number_field :target_daily_cigarette_count, class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
  </div>
  <div>
    <%= f.label :baseline_daily_cigarette_count, "減煙前の1日あたりの本数（基準）", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
    <%= f.number_field :baseline_daily_cigarette_count, class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
  </div>
  <div>
    <%= f.label :pack_price, "1箱の価格（円）", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
    <%= f.number_field :pack_price, class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
  </div>
  <div>
    <%= f.label :cigarettes_per_pack, "1箱あたりの本数", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
    <%= f.number_field :cigarettes_per_pack, value: user_setting.cigarettes_per_pack.presence || 20, class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
  </div>
  <div class="rounded-xl border border-white/10 bg-[#201f1c] p-4">
    <div class="flex items-start gap-3">
      <%= f.check_box :is_oni_mode, class: "mt-1 rounded border-white/20 bg-[#292823] text-amber-300 focus:ring-amber-400" %>
      <div>
        <%= f.label :is_oni_mode, "鬼モードを有効にする", class: "text-sm font-medium text-stone-100" %>
        <p class="mt-1 text-sm text-stone-400">ONにすると、目標本数を超えた日の節約額は増えません。</p>
      </div>
    </div>
  </div>

  <div>
    <%= f.submit "保存する", class: "inline-flex cursor-pointer justify-center rounded-full bg-amber-600 px-5 py-3 text-sm font-bold text-black hover:bg-amber-500" %>
  </div>
<% end %>
