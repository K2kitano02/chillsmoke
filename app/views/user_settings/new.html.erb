<div class="mx-auto max-w-lg px-4 py-8">
  <h1 class="text-2xl font-semibold text-gray-900">初期設定</h1>
  <p class="mt-2 text-sm text-gray-600">目標本数・基準本数・価格を入力して保存してください。</p>

  <%= form_with model: @user_setting, url: user_setting_path, class: "mt-6 space-y-4" do |f| %>
    <% if @user_setting.errors.any? %>
      <div class="rounded-md bg-red-50 p-4 text-sm text-red-800">
        <ul class="list-inside list-disc">
          <% @user_setting.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :target_daily_cigarette_count, "1日の目標本数", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :target_daily_cigarette_count, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm" %>
    </div>
    <div>
      <%= f.label :baseline_daily_cigarette_count, "減煙前の1日あたりの本数（基準）", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :baseline_daily_cigarette_count, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm" %>
    </div>
    <div>
      <%= f.label :pack_price, "1箱の価格（円）", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :pack_price, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm" %>
    </div>
    <div>
      <%= f.label :cigarettes_per_pack, "1箱あたりの本数", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :cigarettes_per_pack, value: @user_setting.cigarettes_per_pack.presence || 20, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm" %>
    </div>
    <div class="flex items-center gap-2">
      <%= f.check_box :is_oni_mode, class: "rounded border-gray-300" %>
      <%= f.label :is_oni_mode, "鬼モード（目標超過日は節約が増えない）", class: "text-sm text-gray-700" %>
    </div>

    <div>
      <%= f.submit "保存する", class: "inline-flex justify-center rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-800" %>
    </div>
  <% end %>
</div>
