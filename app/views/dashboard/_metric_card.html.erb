<div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
  <h2 class="text-sm font-medium text-gray-700"><%= title %></h2>
  <p class="mt-2 text-3xl font-semibold tabular-nums text-gray-900"><%= value %><%= suffix %></p>
  <% if local_assigns[:note].present? %>
    <p class="mt-1 text-xs text-gray-500"><%= note %></p>
  <% end %>
</div>
