<div class="rounded-xl border border-white/10 bg-[#171716] p-5 shadow-sm">
  <h2 class="text-sm font-medium text-stone-400"><%= title %></h2>
  <p class="mt-2 text-3xl font-black tabular-nums tracking-tight text-stone-100"><%= value %><%= suffix %></p>
  <% if local_assigns[:note].present? %>
    <p class="mt-2 text-xs text-stone-500"><%= note %></p>
  <% end %>
</div>
