<div class="mx-auto w-full max-w-5xl">
  <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-medium text-stone-500"><%= Time.zone.today.strftime("%Y年%-m月%-d日") %></p>
      <h1 class="mt-1 text-2xl font-bold tracking-tight text-stone-100">ダッシュボード</h1>
    </div>
  </div>

  <div class="grid gap-4 lg:grid-cols-[1.35fr_1fr]">
    <section class="hemp-surface rounded-xl border border-white/10 bg-[#171716] p-5 shadow-sm sm:p-6">
      <div class="relative flex items-start justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-stone-500">今日の本数</p>
          <p class="mt-3 text-6xl font-semibold tracking-tight text-stone-100 sm:text-7xl"><%= @today_smoking_log.smoking_count %>本</p>
        </div>
        <div class="rounded-lg border border-amber-300/20 bg-amber-400/10 px-3 py-2 text-right">
          <p class="text-xs font-medium text-amber-200">目標本数</p>
          <p class="mt-1 font-bold tabular-nums text-amber-100"><%= @daily_target_count %>本</p>
        </div>
      </div>

      <div class="relative mt-6 rounded-lg bg-[#201f1c] p-4">
        <div class="flex items-center justify-between gap-4 text-sm">
          <span class="font-medium text-stone-400">残り</span>
          <span class="font-bold tabular-nums text-stone-100"><%= @remaining_count %>本</span>
        </div>
        <div class="mt-3 h-2 overflow-hidden rounded-full bg-[#343229]">
          <% progress_percent = @daily_target_count.positive? ? [(@today_smoking_log.smoking_count.to_f / @daily_target_count * 100).round, 100].min : 0 %>
          <div class="h-full rounded-full bg-amber-500" style="width: <%= progress_percent %>%"></div>
        </div>
      </div>

      <% unless @today_smoking_log.persisted? %>
        <p class="relative mt-4 rounded-lg border border-white/10 bg-[#201f1c] px-4 py-3 text-sm text-stone-400">本日分は未記録です。表示用の0本として扱い、DBには保存していません。</p>
      <% end %>

      <div class="relative mt-6 grid gap-3 sm:grid-cols-[1fr_auto]">
        <%= button_to "＋1で記録", increment_today_smoking_log_path, method: :post,
              form: { class: "w-full" },
              class: "w-full rounded-lg bg-amber-600 px-6 py-4 text-base font-bold text-black shadow-sm transition hover:bg-amber-500 active:scale-[0.99]" %>
        <div class="grid gap-3">
          <% unless @today_smoking_log.persisted? %>
            <%= button_to "0本として記録", zero_today_smoking_log_path, method: :post,
                  form: { class: "w-full" },
                  class: "w-full rounded-lg border border-emerald-300/20 bg-emerald-400/10 px-4 py-3 text-sm font-semibold text-emerald-100 transition hover:bg-emerald-400/15 active:scale-[0.99]" %>
          <% end %>
          <%= link_to "日付を指定して修正", new_user_smoking_log_path,
                class: "inline-flex items-center justify-center rounded-lg border border-white/10 bg-white/5 px-4 py-4 text-sm font-semibold text-stone-300 hover:bg-white/10" %>
        </div>
      </div>
    </section>

    <aside class="space-y-4">
      <section class="rounded-xl border border-white/10 bg-[#171716] p-5 shadow-sm">
        <h2 class="text-base font-bold text-stone-100">記録</h2>
        <dl class="mt-4 space-y-3 text-sm">
          <div class="flex items-baseline justify-between gap-4">
            <dt class="text-stone-400">今日の節約見込み額</dt>
            <dd class="font-bold tabular-nums text-stone-100"><%= number_with_delimiter(@savings_summary.today_estimated_saved_yen) %>円</dd>
          </div>
          <div class="flex items-baseline justify-between gap-4">
            <dt class="text-stone-400">累計節約金額</dt>
            <dd class="font-bold tabular-nums text-stone-100"><%= number_with_delimiter(@savings_summary.cumulative_saved_yen) %>円</dd>
          </div>
        </dl>
        <p class="mt-3 text-xs text-stone-500">累計節約金額は昨日までの確定分です。今日の節約見込みは含めていません。</p>
      </section>

      <section class="rounded-xl border border-white/10 bg-[#171716] p-5 shadow-sm">
        <h2 class="text-base font-bold text-stone-100">操作</h2>
        <p class="mt-1 text-xs text-stone-500">記録、予定、欲しいものの確認へ移動できます。</p>
        <div class="mt-4 grid gap-2 text-sm">
          <%= button_to "スケジュールを反映", schedule_reflection_path, method: :post,
                form: { class: "w-full" },
                class: "w-full rounded-lg border border-white/10 bg-[#201f1c] px-4 py-3 text-left font-semibold text-stone-300 hover:bg-white/10" %>
          <%= link_to "喫煙スケジュール", user_schedules_path, class: "rounded-lg border border-white/10 px-4 py-3 font-semibold text-stone-300 hover:bg-white/10" %>
          <%= link_to "喫煙記録カレンダー", calendar_path, class: "rounded-lg border border-white/10 px-4 py-3 font-semibold text-stone-300 hover:bg-white/10" %>
          <%= link_to "ウィッシュリスト", user_wishlists_path, class: "rounded-lg border border-white/10 px-4 py-3 font-semibold text-stone-300 hover:bg-white/10" %>
          <%= link_to "再設定する", edit_user_setting_path, class: "rounded-lg border border-white/10 px-4 py-3 font-semibold text-stone-300 hover:bg-white/10" %>
        </div>
      </section>
    </aside>
  </div>
</div>
