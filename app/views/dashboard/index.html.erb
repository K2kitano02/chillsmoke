<div class="mx-auto w-full max-w-4xl">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900">ダッシュボード</h1>
      <p class="mt-1 text-sm text-gray-600"><%= Time.zone.today.strftime("%Y年%-m月%-d日") %></p>
    </div>
    <div class="flex flex-wrap gap-3">
      <%= link_to "喫煙スケジュール", user_schedules_path, class: "text-sm font-medium text-emerald-800 underline" %>
      <%= link_to "喫煙記録カレンダー", calendar_path, class: "text-sm font-medium text-emerald-800 underline" %>
    </div>
  </div>

  <section class="mt-6 rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
    <div class="grid gap-4 sm:grid-cols-3">
      <%= render "today_stat", title: "今日の本数", value: @today_smoking_log.smoking_count, suffix: "本" %>
      <%= render "today_stat", title: "目標", value: @daily_target_count, suffix: "本" %>
      <%= render "today_stat", title: "残り", value: @remaining_count, suffix: "本" %>
    </div>

    <% unless @today_smoking_log.persisted? %>
      <p class="mt-4 text-xs text-gray-500">本日分は未記録です。表示用の0本として扱い、DBには保存していません。</p>
    <% end %>

    <div class="mt-4 flex flex-wrap items-center gap-3">
      <%= button_to "＋1で記録", increment_today_smoking_log_path, method: :post,
            class: "inline-flex items-center rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-800" %>
      <%= link_to "日付を指定して本数を登録・修正", new_user_smoking_log_path, class: "text-sm text-emerald-800 underline" %>
    </div>
  </section>

  <section class="mt-6 grid gap-4 md:grid-cols-2">
    <%= render "metric_card", title: "累計節約（昨日まで）", value: number_with_delimiter(@savings_summary.cumulative_saved_yen), suffix: "円" %>
    <%= render "metric_card", title: "今日の節約見込み", value: number_with_delimiter(@savings_summary.today_estimated_saved_yen), suffix: "円" %>
    <%= render "metric_card", title: "使用可能金額", value: number_with_delimiter(@balance.usable_yen), suffix: "円", note: "今日の節約見込みは含めていません。" %>
    <%= render "metric_card", title: "継続日数", value: @streak_count, suffix: "日", note: "昨日までの連続達成日数です。" %>
  </section>
</div>
