<div class="mx-auto w-full max-w-6xl"
     data-controller="modal"
     data-modal-initial-open-value="<%= @open_modal %>"
     data-action="keydown@window->modal#closeOnEscape">
  <section class="grid gap-8 py-4 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-amber-300">ChillSmoke</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-stone-100 sm:text-5xl">
        減らした本数を
      </h1>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-stone-100 sm:text-5xl">
        静かに積み上げる。
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-8 text-stone-300">
        ChillSmoke は、毎日の喫煙本数、目標との差、節約できた金額を記録する減煙支援アプリです。
        ただ我慢を数えるのではなく、減らせた分をお金や継続日数として見えます。
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <%= link_to "新規登録して始める", new_user_registration_path, class: "inline-flex justify-center rounded-lg bg-amber-600 px-5 py-3 text-sm font-bold text-black hover:bg-amber-500" %>
        <%= link_to "ログイン", new_user_session_path, class: "inline-flex justify-center rounded-lg border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-stone-200 hover:bg-white/10" %>
      </div>
    </div>

    <div class="portfolio-surface rounded-xl border border-white/10 bg-[#171716] p-5 shadow-sm">
      <div class="relative flex items-center justify-between border-b border-white/10 pb-4">
        <div>
          <p class="text-xs text-stone-500">Today</p>
          <p class="mt-1 text-lg font-bold text-stone-100">今日の記録</p>
        </div>
        <span class="rounded-lg bg-amber-400/10 px-3 py-2 text-sm font-bold text-amber-200">目標 10本</span>
      </div>
      <div class="relative py-8 text-center">
        <p class="text-sm text-stone-500">今日の本数</p>
        <p class="mt-3 text-7xl font-semibold tracking-tight text-stone-100">6本</p>
        <p class="mt-3 text-sm text-stone-400">残り 4本</p>
      </div>
      <div class="relative grid gap-3 text-sm sm:grid-cols-3">
        <div class="rounded-lg bg-[#201f1c] p-4">
          <p class="text-stone-500">節約見込み</p>
          <p class="mt-2 font-bold text-stone-100">120円</p>
        </div>
        <div class="rounded-lg bg-[#201f1c] p-4">
          <p class="text-stone-500">累計節約</p>
          <p class="mt-2 font-bold text-stone-100">4,820円</p>
        </div>
        <div class="rounded-lg bg-[#201f1c] p-4">
          <p class="text-stone-500">継続</p>
          <p class="mt-2 font-bold text-stone-100">16日</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 md:grid-cols-3">
    <div class="rounded-xl border border-white/10 bg-[#171716] p-5">
      <h2 class="text-lg font-bold text-stone-100">本数を記録</h2>
      <p class="mt-3 text-sm leading-6 text-stone-400">今日の本数をすぐ記録、修正可能</p>
    </div>
    <div class="rounded-xl border border-white/10 bg-[#171716] p-5">
      <h2 class="text-lg font-bold text-stone-100">節約額を確認</h2>
      <p class="mt-3 text-sm leading-6 text-stone-400">減煙前の本数と価格から、昨日までの累計と今日の見込みを分けて表示</p>
    </div>
    <div class="rounded-xl border border-white/10 bg-[#171716] p-5">
      <h2 class="text-lg font-bold text-stone-100">欲しいものにつなげる</h2>
      <p class="mt-3 text-sm leading-6 text-stone-400">ウィッシュリストを登録し、貯まった金額で購入できるか確認</p>
    </div>
  </section>

  <footer class="mt-12 border-t border-white/10 py-6">
    <nav aria-label="フッター" class="flex flex-col gap-3 text-sm text-stone-400 sm:flex-row sm:items-center sm:justify-center sm:gap-6">
      <button type="button"
              class="text-left font-semibold text-stone-300 underline underline-offset-4 transition hover:text-amber-200 sm:text-center"
              data-action="modal#open"
              data-modal-name-param="terms">
        利用規約
      </button>
      <button type="button"
              class="text-left font-semibold text-stone-300 underline underline-offset-4 transition hover:text-amber-200 sm:text-center"
              data-action="modal#open"
              data-modal-name-param="privacy">
        プライバシーポリシー
      </button>
      <button type="button"
              class="text-left font-semibold text-stone-300 underline underline-offset-4 transition hover:text-amber-200 sm:text-center"
              data-action="modal#open"
              data-modal-name-param="contact">
        お問い合わせ
      </button>
    </nav>
  </footer>

  <div class="fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto bg-black/75 px-4 py-8 backdrop-blur-sm sm:px-6"
       data-modal-target="overlay"
       data-modal-name="terms"
       data-action="click->modal#closeFromBackdrop"
       role="presentation">
    <section class="mx-auto max-h-[calc(100vh-4rem)] max-w-2xl overflow-y-auto rounded-xl border border-white/10 bg-[#171716] p-6 shadow-2xl sm:p-8"
             role="dialog"
             aria-modal="true"
             aria-labelledby="terms-title"
             data-modal-panel>
      <div class="flex items-start justify-between gap-4 border-b border-white/10 pb-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-wide text-amber-300">Terms</p>
          <h2 id="terms-title" class="mt-1 text-2xl font-black tracking-tight text-stone-100">利用規約</h2>
        </div>
        <button type="button"
                class="rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-semibold text-stone-300 hover:bg-white/10"
                data-action="modal#close">
          閉じる
        </button>
      </div>

      <div class="mt-6 space-y-5 text-sm leading-7 text-stone-300">
        <section>
          <h3 class="font-bold text-stone-100">1. サービスの目的</h3>
          <p class="mt-2">
            ChillSmoke は、喫煙本数、目標、節約額、継続日数を記録し、減煙を支援するためのアプリです。
            医療行為、禁煙治療、専門的な健康指導を提供するものではありません。
          </p>
        </section>

        <section>
          <h3 class="font-bold text-stone-100">2. 表示される数値について</h3>
          <p class="mt-2">
            記録内容、節約額、残高、継続日数などの表示は、ユーザーが入力した設定値と記録に基づく目安です。
            実際の支出、健康状態、禁煙効果を保証するものではありません。
          </p>
        </section>

        <section>
          <h3 class="font-bold text-stone-100">3. 禁止事項</h3>
          <p class="mt-2">
            他者への迷惑行為、不正アクセス、虚偽情報の登録、サービス運営を妨げる行為、法令または公序良俗に反する行為を禁止します。
          </p>
        </section>

        <section>
          <h3 class="font-bold text-stone-100">4. サービス内容の変更・停止</h3>
          <p class="mt-2">
            運営上または技術上必要な場合、事前の通知なくサービス内容の変更、一時停止、終了を行うことがあります。
          </p>
        </section>

        <section>
          <h3 class="font-bold text-stone-100">5. 利用規約の変更</h3>
          <p class="mt-2">
            本規約は、必要に応じて変更される場合があります。変更後の規約は、アプリ上に表示された時点で効力を持つものとします。
          </p>
        </section>
      </div>
    </section>
  </div>

  <div class="fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto bg-black/75 px-4 py-8 backdrop-blur-sm sm:px-6"
       data-modal-target="overlay"
       data-modal-name="privacy"
       data-action="click->modal#closeFromBackdrop"
       role="presentation">
    <section class="mx-auto max-h-[calc(100vh-4rem)] max-w-2xl overflow-y-auto rounded-xl border border-white/10 bg-[#171716] p-6 shadow-2xl sm:p-8"
             role="dialog"
             aria-modal="true"
             aria-labelledby="privacy-title"
             data-modal-panel>
      <div class="flex items-start justify-between gap-4 border-b border-white/10 pb-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-wide text-amber-300">Privacy</p>
          <h2 id="privacy-title" class="mt-1 text-2xl font-black tracking-tight text-stone-100">プライバシーポリシー</h2>
        </div>
        <button type="button"
                class="rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-semibold text-stone-300 hover:bg-white/10"
                data-action="modal#close">
          閉じる
        </button>
      </div>

      <div class="mt-6 space-y-5 text-sm leading-7 text-stone-300">
        <section>
          <h3 class="font-bold text-stone-100">1. 取得する情報</h3>
          <p class="mt-2">
            ChillSmoke は、アカウント管理とサービス提供のため、名前、メールアドレス、喫煙記録、設定値、ウィッシュリスト、購入履歴を取得する場合があります。
          </p>
        </section>

        <section>
          <h3 class="font-bold text-stone-100">2. 利用目的</h3>
          <p class="mt-2">
            取得した情報は、アカウント管理、記録表示、節約額・残高・継続日数の計算、サービス改善のために利用します。
          </p>
        </section>

        <section>
          <h3 class="font-bold text-stone-100">3. 第三者提供</h3>
          <p class="mt-2">
            法令に基づく場合を除き、本人の同意なく個人情報を第三者へ提供しません。
          </p>
        </section>

        <section>
          <h3 class="font-bold text-stone-100">4. 確認・修正・削除相談</h3>
          <p class="mt-2">
            ユーザー本人からの問い合わせがあった場合、本人確認のうえ、登録情報の確認、修正、削除に関する相談に対応します。
          </p>
        </section>

        <section>
          <h3 class="font-bold text-stone-100">5. Cookie・セッション</h3>
          <p class="mt-2">
            ログイン状態の維持、セキュリティ確保、利用状況の把握のため、Cookie やセッションを利用する場合があります。
          </p>
        </section>

        <section>
          <h3 class="font-bold text-stone-100">6. ポリシーの変更</h3>
          <p class="mt-2">
            本ポリシーは、必要に応じて変更される場合があります。変更後の内容は、アプリ上に表示された時点で効力を持つものとします。
          </p>
        </section>
      </div>
    </section>
  </div>

  <div class="fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto bg-black/75 px-4 py-8 backdrop-blur-sm sm:px-6"
       data-modal-target="overlay"
       data-modal-name="contact"
       data-action="click->modal#closeFromBackdrop"
       role="presentation">
    <section class="mx-auto max-h-[calc(100vh-4rem)] w-full max-w-2xl overflow-y-auto rounded-xl border border-white/10 bg-[#171716] p-6 shadow-2xl sm:p-8"
             role="dialog"
             aria-modal="true"
             aria-labelledby="contact-title"
             data-modal-panel>
      <div class="flex items-start justify-between gap-4 border-b border-white/10 pb-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-wide text-amber-300">Contact</p>
          <h2 id="contact-title" class="mt-1 text-2xl font-black tracking-tight text-stone-100">お問い合わせ</h2>
        </div>
        <button type="button"
                class="rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-semibold text-stone-300 hover:bg-white/10"
                data-action="modal#close">
          閉じる
        </button>
      </div>

      <%= form_with model: (@contact_form || ContactForm.new), url: contact_path, data: { turbo: false }, class: "mt-6 space-y-5 text-sm" do |f| %>
        <% if f.object.errors.any? %>
          <div class="rounded-lg border border-red-400/30 bg-red-950/40 px-4 py-3 text-red-200" role="alert">
            <p class="font-bold">入力内容を確認してください。</p>
            <ul class="mt-2 list-disc space-y-1 pl-5">
              <% f.object.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :name, "名前", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
          <%= f.text_field :name, autocomplete: "name", placeholder: "例: ChillUser", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 placeholder:text-stone-500 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
        </div>

        <div>
          <%= f.label :email, "メールアドレス", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
          <%= f.email_field :email, autocomplete: "email", placeholder: "email@example.com", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 placeholder:text-stone-500 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
        </div>

        <div>
          <%= f.label :message, "お問い合わせ内容", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
          <%= f.text_area :message, rows: 6, placeholder: "不具合・ご要望・ご相談内容を入力してください", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 placeholder:text-stone-500 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <%= f.submit "送信する", class: "inline-flex w-full cursor-pointer justify-center rounded-lg bg-amber-600 px-5 py-3 text-sm font-bold text-black transition hover:bg-amber-500 sm:w-auto" %>
          <a href="https://x.com/K2kitano02"
             target="_blank"
             rel="noopener"
             class="inline-flex w-full justify-center rounded-lg border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-stone-300 transition hover:bg-white/10 sm:w-auto">
            Xで連絡する
          </a>
        </div>
      <% end %>
    </section>
  </div>
</div>
