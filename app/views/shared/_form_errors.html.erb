<% if record.errors.any? %>
  <div class="rounded-lg border border-red-400/30 bg-red-50 bg-red-950/40 p-4 text-sm text-red-200" role="alert">
    <p class="font-medium">入力内容を確認してください。</p>
    <ul class="mt-2 list-inside list-disc text-red-200">
      <% record.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>
