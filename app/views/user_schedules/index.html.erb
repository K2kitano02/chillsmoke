<div class="mx-auto max-w-3xl">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900">喫煙スケジュール</h1>
      <p class="mt-1 text-sm text-gray-600">登録済みの固定時間を確認できます。</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <%= link_to "新規登録", new_user_schedule_path, class: "text-sm font-medium text-emerald-800 underline" %>
      <%= link_to "ダッシュボードへ戻る", dashboard_path, class: "text-sm font-medium text-emerald-800 underline" %>
    </div>
  </div>

  <% if @user_schedules.any? %>
    <div class="mt-6 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50 text-left text-gray-700">
          <tr>
            <th scope="col" class="px-4 py-3 font-medium">時刻</th>
            <th scope="col" class="px-4 py-3 font-medium">ラベル</th>
            <th scope="col" class="px-4 py-3 font-medium">状態</th>
            <th scope="col" class="px-4 py-3 font-medium">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @user_schedules.each do |schedule| %>
            <tr>
              <td class="px-4 py-3 font-semibold tabular-nums text-gray-900"><%= schedule.scheduled_smoking_time.strftime("%H:%M") %></td>
              <td class="px-4 py-3 text-gray-700"><%= schedule.label.presence || "未設定" %></td>
              <td class="px-4 py-3 text-gray-700"><%= schedule.is_active? ? "有効" : "停止中" %></td>
              <td class="px-4 py-3">
                <%= link_to "編集", edit_user_schedule_path(schedule), class: "text-sm font-medium text-emerald-800 underline" %>
                <%= button_to toggle_user_schedule_path(schedule), method: :patch,
                      form: { class: "mt-2 inline-block align-middle" },
                      class: "inline-flex h-6 w-11 items-center rounded-full p-0.5 transition #{schedule.is_active? ? "bg-emerald-600" : "bg-gray-300"}",
                      title: schedule.is_active? ? "停止する" : "有効にする",
                      aria: { label: schedule.is_active? ? "停止する" : "有効にする" } do %>
                  <span class="sr-only"><%= schedule.is_active? ? "停止する" : "有効にする" %></span>
                  <span class="h-5 w-5 rounded-full bg-white shadow-sm transition <%= schedule.is_active? ? "translate-x-5" : "translate-x-0" %>"></span>
                <% end %>
                <%= button_to "削除", user_schedule_path(schedule), method: :delete,
                      form: { class: "mt-2 inline-block" },
                      class: "text-sm font-medium text-red-700 underline",
                      data: { turbo_confirm: "このスケジュールを削除しますか？" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="mt-6 rounded-lg border border-dashed border-gray-300 bg-white p-6 text-sm text-gray-600">
      まだスケジュールは登録されていません。
    </div>
  <% end %>
</div>
