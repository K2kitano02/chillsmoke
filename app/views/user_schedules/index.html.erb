<div class="mx-auto w-full max-w-5xl">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-xs font-bold uppercase tracking-wide text-amber-300">Schedule</p>
      <h1 class="mt-1 text-3xl font-black tracking-tight text-stone-100">喫煙スケジュール</h1>
      <p class="mt-2 text-sm text-stone-400">登録済みの固定時間を確認できます。</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <%= link_to "新規登録", new_user_schedule_path, class: "rounded-full bg-amber-600 px-4 py-2 text-sm font-bold text-black hover:bg-amber-500" %>
      <%= link_to "ダッシュボードへ戻る", dashboard_path, class: "rounded-full bg-[#292823] px-4 py-2 text-sm font-semibold text-stone-100 ring-1 ring-white/10 hover:bg-[#343229]" %>
    </div>
  </div>

  <% if @user_schedules.any? %>
    <div class="mt-6 grid gap-3 md:hidden">
      <% @user_schedules.each do |schedule| %>
        <article class="rounded-xl border border-white/10 bg-[#171716] p-4 shadow-sm">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="text-xs font-bold uppercase tracking-wide text-stone-500">時刻</p>
              <p class="mt-1 text-2xl font-black tabular-nums text-stone-100"><%= schedule.scheduled_smoking_time %></p>
            </div>
            <span class="inline-flex shrink-0 items-center justify-center whitespace-nowrap rounded-full px-3 py-1 text-xs font-bold <%= schedule.is_active? ? "bg-amber-600 text-black" : "bg-[#292823] text-stone-300" %>">
              <%= schedule.is_active? ? "有効" : "停止中" %>
            </span>
          </div>

          <div class="mt-4 min-w-0">
            <p class="text-xs font-bold uppercase tracking-wide text-stone-500">ラベル</p>
            <p class="mt-1 break-words text-sm font-semibold leading-6 text-stone-200"><%= schedule.label.presence || "未設定" %></p>
          </div>

          <div class="mt-4 flex flex-wrap items-center gap-3 border-t border-white/10 pt-4">
            <%= link_to "編集", edit_user_schedule_path(schedule), class: "text-sm font-semibold text-amber-300 underline underline-offset-4" %>
            <%= button_to toggle_user_schedule_path(schedule), method: :patch,
                  form: { class: "inline-block align-middle" },
                  class: "inline-flex h-7 w-12 items-center rounded-full p-0.5 transition #{schedule.is_active? ? "bg-amber-500" : "bg-[#343229]"}",
                  title: schedule.is_active? ? "停止する" : "有効にする",
                  aria: { label: schedule.is_active? ? "停止する" : "有効にする" } do %>
              <span class="sr-only"><%= schedule.is_active? ? "停止する" : "有効にする" %></span>
              <span class="h-6 w-6 rounded-full bg-[#171716] shadow-sm transition <%= schedule.is_active? ? "translate-x-5" : "translate-x-0" %>"></span>
            <% end %>
            <%= button_to "削除", user_schedule_path(schedule), method: :delete,
                  form: { class: "inline-block" },
                  class: "text-sm font-semibold text-red-200 underline underline-offset-4",
                  data: { turbo_confirm: "このスケジュールを削除しますか？" } %>
          </div>
        </article>
      <% end %>
    </div>

    <div class="mt-6 hidden overflow-x-auto rounded-xl border border-white/10 bg-[#171716] shadow-sm md:block">
      <table class="min-w-full divide-y divide-white/10 text-sm">
        <thead class="bg-[#201f1c] text-left text-stone-300">
          <tr>
            <th scope="col" class="whitespace-nowrap px-4 py-3 font-medium">時刻</th>
            <th scope="col" class="px-4 py-3 font-medium">ラベル</th>
            <th scope="col" class="whitespace-nowrap px-4 py-3 font-medium">状態</th>
            <th scope="col" class="whitespace-nowrap px-4 py-3 font-medium">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/10">
          <% @user_schedules.each do |schedule| %>
            <tr class="hover:bg-[#201f1c]">
              <td class="whitespace-nowrap px-4 py-4 font-semibold tabular-nums text-stone-100"><%= schedule.scheduled_smoking_time %></td>
              <td class="px-4 py-4 text-stone-300"><%= schedule.label.presence || "未設定" %></td>
              <td class="px-4 py-4 text-stone-300">
                <span class="inline-flex items-center justify-center whitespace-nowrap rounded-full px-3 py-1 text-xs font-bold <%= schedule.is_active? ? "bg-amber-600 text-black" : "bg-[#292823] text-stone-300" %>"><%= schedule.is_active? ? "有効" : "停止中" %></span>
              </td>
              <td class="whitespace-nowrap px-4 py-3">
                <%= link_to "編集", edit_user_schedule_path(schedule), class: "text-sm font-semibold text-amber-300 underline underline-offset-4" %>
                <%= button_to toggle_user_schedule_path(schedule), method: :patch,
                      form: { class: "mt-2 inline-block align-middle" },
                      class: "inline-flex h-6 w-11 items-center rounded-full p-0.5 transition #{schedule.is_active? ? "bg-amber-500" : "bg-[#343229]"}",
                      title: schedule.is_active? ? "停止する" : "有効にする",
                      aria: { label: schedule.is_active? ? "停止する" : "有効にする" } do %>
                  <span class="sr-only"><%= schedule.is_active? ? "停止する" : "有効にする" %></span>
                  <span class="h-5 w-5 rounded-full bg-[#171716] shadow-sm transition <%= schedule.is_active? ? "translate-x-5" : "translate-x-0" %>"></span>
                <% end %>
                <%= button_to "削除", user_schedule_path(schedule), method: :delete,
                      form: { class: "mt-2 inline-block" },
                      class: "text-sm font-semibold text-red-200 underline underline-offset-4",
                      data: { turbo_confirm: "このスケジュールを削除しますか？" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="mt-6 rounded-xl border border-dashed border-white/10 bg-[#201f1c] p-6 text-sm text-stone-400">
      まだスケジュールは登録されていません。
    </div>
  <% end %>
</div>
