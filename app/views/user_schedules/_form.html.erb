<%= form_with model: user_schedule, class: "mt-6 space-y-4" do |f| %>
  <%= render "shared/form_errors", record: user_schedule %>

  <div>
    <%= f.label :scheduled_smoking_time, "時刻", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
    <%= f.time_field :scheduled_smoking_time, class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
  </div>

  <div>
    <%= f.label :label, "ラベル", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
    <%= f.text_field :label, placeholder: "例: 朝、昼休み、仕事終わり", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 placeholder:text-stone-500 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
  </div>

  <div class="rounded-xl border border-white/10 bg-[#201f1c] p-4">
    <div class="flex items-start gap-3">
      <%= f.check_box :is_active, class: "mt-1 rounded border-white/20 bg-[#292823] text-amber-300 focus:ring-amber-400" %>
      <div>
        <%= f.label :is_active, "有効にする", class: "text-sm font-medium text-stone-100" %>
        <p class="mt-1 text-sm text-stone-400">ONのスケジュールは、後続の反映機能で当日の記録対象になります。</p>
      </div>
    </div>
  </div>

  <div class="flex flex-wrap items-center gap-3">
    <%= f.submit submit_label, class: "inline-flex cursor-pointer justify-center rounded-full bg-amber-600 px-5 py-3 text-sm font-bold text-black hover:bg-amber-500" %>
    <%= link_to "一覧へ戻る", user_schedules_path, class: "text-sm font-semibold text-amber-300 underline underline-offset-4" %>
  </div>
<% end %>
