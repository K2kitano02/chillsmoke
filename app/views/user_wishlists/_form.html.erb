<%= form_with model: user_wishlist, class: "mt-6 space-y-4" do |f| %>
  <%= render "shared/form_errors", record: user_wishlist %>

  <div>
    <%= f.label :name, "名前", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
    <%= f.text_field :name, placeholder: "例: 腕時計、イヤホン", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 placeholder:text-stone-500 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
  </div>

  <div>
    <%= f.label :price, "価格", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
    <%= f.number_field :price, min: 1, step: 1, class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
  </div>

  <div>
    <%= f.label :memo, "メモ", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
    <%= f.text_area :memo, rows: 4, placeholder: "購入理由や候補メモ", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 placeholder:text-stone-500 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
  </div>

  <div class="flex flex-wrap items-center gap-3">
    <%= f.submit submit_label, class: "inline-flex cursor-pointer justify-center rounded-full bg-amber-600 px-5 py-3 text-sm font-bold text-black hover:bg-amber-500" %>
    <%= link_to "一覧へ戻る", user_wishlists_path, class: "text-sm font-semibold text-amber-300 underline underline-offset-4" %>
  </div>
<% end %>
