<div class="mx-auto w-full max-w-5xl">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-xs font-bold uppercase tracking-wide text-amber-300">Wishlist</p>
      <h1 class="mt-1 text-3xl font-black tracking-tight text-stone-100">ウィッシュリスト</h1>
      <p class="mt-2 text-sm text-stone-400">減煙で貯めたお金の使い道を確認できます。</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <%= link_to "新規登録", new_user_wishlist_path, class: "rounded-full bg-amber-600 px-4 py-2 text-sm font-bold text-black hover:bg-amber-500" %>
      <%= link_to "ダッシュボードへ戻る", dashboard_path, class: "rounded-full bg-[#292823] px-4 py-2 text-sm font-semibold text-stone-100 ring-1 ring-white/10 hover:bg-[#343229]" %>
    </div>
  </div>

  <% if @user_wishlists.any? %>
    <div class="mt-6 overflow-x-auto rounded-xl border border-white/10 bg-[#171716] shadow-sm">
      <table class="min-w-full divide-y divide-white/10 text-sm">
        <thead class="bg-[#201f1c] text-left text-stone-300">
          <tr>
            <th scope="col" class="px-4 py-3 font-medium">名前</th>
            <th scope="col" class="px-4 py-3 font-medium">価格</th>
            <th scope="col" class="px-4 py-3 font-medium">メモ</th>
            <th scope="col" class="px-4 py-3 font-medium">状態</th>
            <th scope="col" class="px-4 py-3 font-medium">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/10">
          <% @user_wishlists.each do |wishlist| %>
            <tr class="hover:bg-[#201f1c]">
              <td class="px-4 py-4 font-semibold text-stone-100">
                <%= link_to wishlist.name, user_wishlist_path(wishlist), class: "text-amber-300 underline underline-offset-4" %>
              </td>
              <td class="px-4 py-4 tabular-nums text-stone-300"><%= number_with_delimiter(wishlist.price) %>円</td>
              <td class="px-4 py-4 text-stone-300"><%= wishlist.memo.presence || "未設定" %></td>
              <td class="px-4 py-4 text-stone-300">
                <span class="rounded-full px-3 py-1 text-xs font-bold <%= wishlist.is_purchased? ? "bg-amber-600 text-black" : "bg-[#292823] text-stone-300" %>"><%= wishlist.is_purchased? ? "購入済み" : "未購入" %></span>
              </td>
              <td class="px-4 py-3">
                <%= button_to "削除", user_wishlist_path(wishlist), method: :delete,
                      form: { class: "inline-block" },
                      class: "text-sm font-semibold text-red-200 underline underline-offset-4",
                      data: { turbo_confirm: "このウィッシュリストを削除しますか？" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="mt-6 rounded-xl border border-dashed border-white/10 bg-[#201f1c] p-6 text-sm text-stone-400">
      まだウィッシュリストは登録されていません。
    </div>
  <% end %>
</div>
