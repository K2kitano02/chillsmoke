<div class="mx-auto max-w-3xl">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900">ウィッシュリスト</h1>
      <p class="mt-1 text-sm text-gray-600">減煙で貯めたお金の使い道を確認できます。</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <%= link_to "新規登録", new_user_wishlist_path, class: "text-sm font-medium text-emerald-800 underline" %>
      <%= link_to "ダッシュボードへ戻る", dashboard_path, class: "text-sm font-medium text-emerald-800 underline" %>
    </div>
  </div>

  <% if @user_wishlists.any? %>
    <div class="mt-6 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50 text-left text-gray-700">
          <tr>
            <th scope="col" class="px-4 py-3 font-medium">名前</th>
            <th scope="col" class="px-4 py-3 font-medium">価格</th>
            <th scope="col" class="px-4 py-3 font-medium">メモ</th>
            <th scope="col" class="px-4 py-3 font-medium">状態</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @user_wishlists.each do |wishlist| %>
            <tr>
              <td class="px-4 py-3 font-semibold text-gray-900">
                <%= link_to wishlist.name, user_wishlist_path(wishlist), class: "text-emerald-800 underline" %>
              </td>
              <td class="px-4 py-3 tabular-nums text-gray-700"><%= number_with_delimiter(wishlist.price) %>円</td>
              <td class="px-4 py-3 text-gray-700"><%= wishlist.memo.presence || "未設定" %></td>
              <td class="px-4 py-3 text-gray-700"><%= wishlist.is_purchased? ? "購入済み" : "未購入" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="mt-6 rounded-lg border border-dashed border-gray-300 bg-white p-6 text-sm text-gray-600">
      まだウィッシュリストは登録されていません。
    </div>
  <% end %>
</div>
