<div>
  <%= form.label field, label_text, class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>

  <% if local_assigns[:hint].present? %>
    <p class="ml-1 mt-1 text-xs text-stone-500"><%= hint %></p>
  <% end %>

  <div class="relative mt-2" data-controller="password-reveal">
    <%= form.password_field field,
          autocomplete: autocomplete,
          placeholder: local_assigns[:placeholder],
          class: "block w-full rounded-lg border-0 bg-[#292823] py-3 pl-4 pr-14 text-stone-100 placeholder:text-stone-500 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400",
          data: {
            password_reveal_target: "input",
            action: "blur->password-reveal#hide keydown->password-reveal#hideOnEscape"
          } %>

    <button type="button"
            class="absolute right-2 top-1/2 inline-flex h-8 min-w-10 -translate-y-1/2 items-center justify-center rounded-md border border-white/10 bg-[#171716]/95 px-2 text-xs font-bold text-amber-200 shadow-sm hover:bg-[#211f1b] focus:outline-none focus:ring-2 focus:ring-amber-400"
            aria-label="<%= label_text %>を押している間だけ表示"
            data-action="pointerdown->password-reveal#show pointerup->password-reveal#hide pointerleave->password-reveal#hide pointercancel->password-reveal#hide touchstart->password-reveal#show touchend->password-reveal#hide touchcancel->password-reveal#hide blur->password-reveal#hide keydown->password-reveal#showOnActivation keydown.esc->password-reveal#hide keyup->password-reveal#hide">
      表示
    </button>
  </div>

  <% if local_assigns[:support_text].present? %>
    <p class="ml-1 mt-1 text-xs text-stone-500"><%= support_text %></p>
  <% end %>
</div>
