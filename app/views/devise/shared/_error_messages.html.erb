<% if resource.errors.any? %>
  <div id="error_explanation" class="mb-4 rounded-lg border border-red-300/20 bg-red-950/40 p-4" data-turbo-temporary>
    <h2 class="text-sm font-semibold text-red-200">
      入力内容を確認してください（<%= resource.errors.count %>件のエラー）
    </h2>
    <ul class="mt-2 list-disc pl-5 text-sm text-red-200">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
