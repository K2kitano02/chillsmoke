<div class="mx-auto flex min-h-[calc(100vh-9rem)] w-full max-w-md items-center py-4">
  <div class="portfolio-surface w-full rounded-xl border border-white/10 bg-[#171716]/95 p-6 shadow-sm sm:p-8">
    <div class="relative mb-8 text-center">
      <h2 class="text-3xl font-black tracking-tight text-amber-300">ChillSmoke</h2>
      <p class="mt-2 text-sm font-medium text-stone-400">新しいパスワードを設定</p>
    </div>

    <%= form_for(resource, as: resource_name, url: user_password_path, html: { method: :put, class: "relative space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <%= render "devise/shared/password_field_with_reveal",
            form: f,
            field: :password,
            label_text: "新しいパスワード",
            autocomplete: "new-password",
            placeholder: "••••••••",
            hint: (@minimum_password_length ? "（#{@minimum_password_length}文字以上）" : nil) %>

      <%= render "devise/shared/password_field_with_reveal",
            form: f,
            field: :password_confirmation,
            label_text: "新しいパスワード（確認）",
            autocomplete: "new-password",
            placeholder: "••••••••" %>

      <%= f.submit "パスワードを変更する", class: "w-full cursor-pointer rounded-full bg-amber-600 px-5 py-3 font-bold text-black hover:bg-amber-500" %>
    <% end %>

    <div class="relative mt-8 border-t border-white/10 pt-6 text-center text-sm text-stone-400">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
