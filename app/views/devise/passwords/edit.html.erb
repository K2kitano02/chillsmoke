<div class="mx-auto flex min-h-[calc(100vh-9rem)] w-full max-w-md items-center py-4">
  <div class="w-full rounded-xl border border-white/10 bg-[#171716] p-6 shadow-sm sm:p-8">
    <h2 class="text-3xl font-black tracking-tight text-stone-100">パスワードの変更</h2>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "mt-6 space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div>
        <%= f.label :password, "新しいパスワード", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
        <% if @minimum_password_length %>
          <p class="ml-1 mt-1 text-xs text-stone-500">（<%= @minimum_password_length %>文字以上）</p>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
      </div>

      <%= f.submit "パスワードを変更する", class: "w-full cursor-pointer rounded-full bg-amber-600 px-5 py-3 font-bold text-black hover:bg-amber-500" %>
    <% end %>

    <div class="mt-8 border-t border-white/10 pt-6 text-center text-sm text-stone-400">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
