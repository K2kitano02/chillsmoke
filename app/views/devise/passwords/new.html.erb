<div class="mx-auto flex min-h-[calc(100vh-9rem)] w-full max-w-md items-center py-4">
  <div class="portfolio-surface w-full rounded-xl border border-white/10 bg-[#171716]/95 p-6 shadow-sm sm:p-8">
    <div class="relative mb-8 text-center">
      <h2 class="text-3xl font-black tracking-tight text-amber-300">ChillSmoke</h2>
      <p class="mt-2 text-sm font-medium text-stone-400">パスワード再設定</p>
    </div>

    <%= form_for(resource, as: resource_name, url: user_password_path, html: { method: :post, class: "relative space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, "メールアドレス", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "email@example.com", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 placeholder:text-stone-500 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
      </div>

      <%= f.submit "再設定メールを送信する", class: "w-full cursor-pointer rounded-full bg-amber-600 px-5 py-3 font-bold text-black hover:bg-amber-500" %>
    <% end %>

    <div class="relative mt-8 border-t border-white/10 pt-6 text-center text-sm text-stone-400">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
