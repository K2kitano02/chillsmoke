<div class="mx-auto flex min-h-[calc(100vh-9rem)] w-full max-w-2xl items-center py-4">
  <div class="w-full rounded-xl border border-white/10 bg-[#171716] p-6 shadow-sm sm:p-8">
    <h2 class="text-3xl font-black tracking-tight text-stone-100">アカウント設定</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "mt-6 space-y-5" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :name, "名前", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
      <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
    </div>

    <div>
      <%= f.label :email, "メールアドレス", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
      <%= f.email_field :email, autocomplete: "email", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
    </div>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <div class="rounded-lg border border-amber-200/20 bg-amber-500/10 p-3 text-sm text-amber-100">確認待ちのメールアドレス: <%= resource.unconfirmed_email %></div>
    <% end %>

    <div>
      <%= f.label :password, "新しいパスワード", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
      <p class="ml-1 mt-1 text-xs text-stone-500">（変更しない場合は空のまま）</p>
      <%= f.password_field :password, autocomplete: "new-password", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
      <% if @minimum_password_length %>
        <p class="ml-1 mt-1 text-xs text-stone-500">（<%= @minimum_password_length %>文字以上）</p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
    </div>

    <div>
      <%= f.label :current_password, "現在のパスワード", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
      <p class="ml-1 mt-1 text-xs text-stone-500">（変更を保存するには現在のパスワードを入力してください）</p>
      <%= f.password_field :current_password, autocomplete: "current-password", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
    </div>

    <%= f.submit "更新する", class: "inline-flex cursor-pointer rounded-full bg-amber-600 px-5 py-3 text-sm font-bold text-black hover:bg-amber-500" %>
    <% end %>

    <h3 class="mt-8 text-lg font-semibold text-stone-100">アカウントの削除</h3>

    <div class="mt-2">
      <%= button_to "アカウントを削除する", registration_path(resource_name),
            data: { confirm: "本当に削除しますか？", turbo_confirm: "本当に削除しますか？" },
            method: :delete,
            class: "rounded-full border border-red-400/30 bg-red-950/40 px-4 py-2 text-sm font-semibold text-red-200 hover:bg-red-950/60" %>
    </div>

    <%= link_to "戻る", :back, class: "mt-4 inline-block text-sm font-semibold text-amber-300 underline underline-offset-4" %>
  </div>
</div>
