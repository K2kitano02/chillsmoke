<h2 class="text-2xl font-bold text-slate-800 mb-4">アカウント設定</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field mb-3">
    <p><%= f.label :name, "名前" %></p>
    <p><%= f.text_field :name, autofocus: true, autocomplete: "name" %></p>
  </div>

  <div class="field mb-3">
    <p><%= f.label :email, "メールアドレス" %></p>
    <p><%= f.email_field :email, autocomplete: "email" %></p>
  </div>

  <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
    <div class="mb-3 text-amber-800">確認待ちのメールアドレス: <%= resource.unconfirmed_email %></div>
  <% end %>

  <div class="field mb-3">
    <p><%= f.label :password, "新しいパスワード" %></p>
    <p class="text-sm text-slate-500">（変更しない場合は空のまま）</p>
    <p><%= f.password_field :password, autocomplete: "new-password" %></p>
    <% if @minimum_password_length %>
      <p class="text-sm text-slate-500">（<%= @minimum_password_length %>文字以上）</p>
    <% end %>
  </div>

  <div class="field mb-3">
    <p><%= f.label :password_confirmation, "新しいパスワード（確認）" %></p>
    <p><%= f.password_field :password_confirmation, autocomplete: "new-password" %></p>
  </div>

  <div class="field mb-3">
    <p><%= f.label :current_password, "現在のパスワード" %></p>
    <p class="text-sm text-slate-500">（変更を保存するには現在のパスワードを入力してください）</p>
    <p><%= f.password_field :current_password, autocomplete: "current-password" %></p>
  </div>

  <div class="actions">
    <%= f.submit "更新する", class: "rounded bg-emerald-600 px-4 py-2 text-white hover:bg-emerald-500" %>
  </div>
<% end %>

<h3 class="mt-8 text-lg font-semibold text-slate-800">アカウントの削除</h3>

<div class="mt-2">
  <%= button_to "アカウントを削除する", registration_path(resource_name),
        data: { confirm: "本当に削除しますか？", turbo_confirm: "本当に削除しますか？" },
        method: :delete,
        class: "rounded border border-red-200 bg-red-50 px-3 py-1.5 text-red-800 hover:bg-red-100" %>
</div>

<%= link_to "戻る", :back, class: "mt-4 inline-block text-emerald-700 hover:underline" %>
