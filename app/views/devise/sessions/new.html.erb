<div class="mx-auto flex min-h-[calc(100vh-9rem)] w-full max-w-md items-center">
  <div class="hemp-surface w-full rounded-xl border border-white/10 bg-[#171716]/95 p-6 shadow-sm sm:p-8">
    <div class="relative mb-8 text-center">
      <h2 class="text-3xl font-black tracking-tight text-amber-300">ChillSmoke</h2>
      <p class="mt-2 text-sm font-medium text-stone-400">アカウントにログイン</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "relative space-y-5" }) do |f| %>
      <div>
        <%= f.label :email, "メールアドレス", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "email@example.com", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 placeholder:text-stone-500 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
      </div>

      <div>
        <%= f.label :password, "パスワード", class: "ml-1 block text-xs font-bold uppercase tracking-wide text-stone-400" %>
        <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", class: "mt-2 block w-full rounded-lg border-0 bg-[#292823] px-4 py-3 text-stone-100 placeholder:text-stone-500 ring-1 ring-white/10 focus:ring-2 focus:ring-amber-400" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2 text-sm text-stone-300">
          <%= f.check_box :remember_me, class: "rounded border-white/20 bg-[#292823] text-amber-300 focus:ring-amber-400" %>
          <%= f.label :remember_me, "ログインしたままにする" %>
        </div>
      <% end %>

      <%= f.submit "ログイン", class: "w-full cursor-pointer rounded-full bg-amber-600 px-5 py-3 font-bold text-black hover:bg-amber-500" %>
    <% end %>

    <div class="relative mt-8 border-t border-white/10 pt-6 text-center text-sm text-stone-400">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
