<h2 class="text-2xl font-bold text-slate-800 mb-4">ログイン</h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <div class="field mb-3">
    <p><%= f.label :email, "メールアドレス" %></p>
    <p><%= f.email_field :email, autofocus: true, autocomplete: "email" %></p>
  </div>

  <div class="field mb-3">
    <p><%= f.label :password, "パスワード" %></p>
    <p><%= f.password_field :password, autocomplete: "current-password" %></p>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="field mb-3 flex items-center gap-2">
      <%= f.check_box :remember_me %>
      <%= f.label :remember_me, "ログインしたままにする" %>
    </div>
  <% end %>

  <div class="actions">
    <%= f.submit "ログイン", class: "rounded bg-emerald-600 px-4 py-2 text-white hover:bg-emerald-500" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
